# MosAIc — Environment Variables
# Copy this to .env and fill in your values.
# Never commit .env to git.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── App Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=mosaic-local-dev-secret-change-in-prod

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Defaults to localhost:5173/3000 if unset — only needed once a real domain exists.
# CORS_ORIGINS=https://app.mosaic-demo.com

# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset for local dev — defaults to a SQLite file at the project root.
# On AWS, set this to the RDS Postgres connection string, e.g.:
# DATABASE_URL=postgresql+psycopg2://mosaic_app:<password>@<rds-endpoint>:5432/mosaic

# ── Langfuse Observability ────────────────────────────────────────────────────
# Sign up free at https://cloud.langfuse.com
# Keys are found under Settings → API Keys in your Langfuse project
#
# IMPORTANT: Do not swap these — the naming is counterintuitive:
#   LANGFUSE_PUBLIC_KEY  must start with  pk-lf-...
#   LANGFUSE_SECRET_KEY  must start with  sk-lf-...
#
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
